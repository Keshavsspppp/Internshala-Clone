# MongoDB Connection URL
DATABASE_URL=
# Server Port (optional, defaults to 5000)
PORT=5000

# Node Environment
NODE_ENV=development

# Default admin account
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@internarea.com
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=admin

# Razorpay API Credentials
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# JWT Configuration for Admin Panel
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# SMTP Email Configuration (Nodemailer)
# For Gmail, set SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true
# Passwords should be a 16-character Gmail App Password (not your account password)
SMTP_HOST=your_smtp_host_here
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user_email_here
SMTP_PASS=your_smtp_password_or_app_password_here
SMTP_FROM=your_smtp_sender_email_here
